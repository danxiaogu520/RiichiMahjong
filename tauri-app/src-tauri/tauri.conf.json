{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "联网日麻",
  "version": "0.1.0",
  "identifier": "com.riichi.mahjong",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "联网日麻",
        "width": 1280,
        "height": 900,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http: https: ws: wss:; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Game",
    "shortDescription": "四人联网立直麻将客户端",
    "longDescription": "通过房间码和朋友进行服务端权威的四人立直麻将对局。",
    "copyright": "Copyright © 2026 Riichi Mahjong contributors"
  }
}
